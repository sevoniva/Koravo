<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="https://koravo.io/examples">
  <process id="leaveApproval" name="Leave Approval" isExecutable="true">
    <startEvent id="start" name="Start"/>
    <sequenceFlow id="flow_start_approve" sourceRef="start" targetRef="approveTask"/>

    <userTask id="approveTask" name="Approve Leave" flowable:assignee="${approver}"/>
    <sequenceFlow id="flow_approve_gateway" sourceRef="approveTask" targetRef="approvalGateway"/>

    <exclusiveGateway id="approvalGateway" name="Approved?"/>
    <sequenceFlow id="flow_approved" sourceRef="approvalGateway" targetRef="approvedEnd">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${approved == true}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_rejected" sourceRef="approvalGateway" targetRef="rejectedEnd">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${approved != true}]]></conditionExpression>
    </sequenceFlow>

    <endEvent id="approvedEnd" name="Approved"/>
    <endEvent id="rejectedEnd" name="Rejected"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_leaveApproval">
    <bpmndi:BPMNPlane id="BPMNPlane_leaveApproval" bpmnElement="leaveApproval">
      <bpmndi:BPMNShape id="Shape_start" bpmnElement="start">
        <omgdc:Bounds x="80" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_approveTask" bpmnElement="approveTask">
        <omgdc:Bounds x="170" y="78" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_gateway" bpmnElement="approvalGateway" isMarkerVisible="true">
        <omgdc:Bounds x="350" y="93" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_approvedEnd" bpmnElement="approvedEnd">
        <omgdc:Bounds x="470" y="45" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_rejectedEnd" bpmnElement="rejectedEnd">
        <omgdc:Bounds x="470" y="150" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_flow_start_approve" bpmnElement="flow_start_approve">
        <omgdi:waypoint x="116" y="118"/>
        <omgdi:waypoint x="170" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_flow_approve_gateway" bpmnElement="flow_approve_gateway">
        <omgdi:waypoint x="290" y="118"/>
        <omgdi:waypoint x="350" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_flow_approved" bpmnElement="flow_approved">
        <omgdi:waypoint x="375" y="93"/>
        <omgdi:waypoint x="488" y="81"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_flow_rejected" bpmnElement="flow_rejected">
        <omgdi:waypoint x="375" y="143"/>
        <omgdi:waypoint x="488" y="150"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
